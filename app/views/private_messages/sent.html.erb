<div class="flex flex-col gap-6">
  <%# Header %>
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <h1 class="text-3xl font-bold text-cs-dark-red">Nachrichten</h1>
    <%= link_to new_private_message_path, class: 'btn btn-primary' do %>
      <i class="fas fa-plus mr-2"></i> Neue Nachricht
    <% end %>
  </div>

  <%# Tab Navigation %>
  <nav class="flex gap-2 border-b border-gray-200">
    <%= link_to private_messages_path,
      class: "px-4 py-2 font-medium text-gray-500 hover:text-cs-dark-red hover:border-gray-300 border-b-2 border-transparent" do %>
      Konversationen
    <% end %>
    <%= link_to sent_private_messages_path,
      class: "px-4 py-2 font-medium border-b-2 border-cs-dark-red text-cs-dark-red" do %>
      Gesendet
    <% end %>
  </nav>

  <% if @messages.any? %>
    <%# Mobile View (Cards) %>
    <div class="lg:hidden space-y-3">
      <% @messages.each do |message| %>
        <% other_user = message.sender_id == Current.user.id ? message.receiver : message.sender %>
        <% has_unread = @unread_partner_ids.include?(other_user.id) %>
        <div class="card">
          <div class="card-body p-4">
            <div class="flex items-start justify-between mb-2">
              <div class="text-sm text-gray-600">
                Mit: <%= user_badge(other_user) %>
                <% if has_unread %>
                  <span class="ml-1 inline-block w-2 h-2 bg-cs-dark-red rounded-full align-middle"></span>
                <% end %>
              </div>
            </div>

            <div class="text-sm mb-2 <%= has_unread ? 'font-semibold' : 'text-gray-700' %>">
              <%= link_to truncate(message.body, length: 80), private_message_path(message),
                class: "hover:underline" %>
            </div>

            <div class="text-xs text-gray-400">
              <%= time_ago_in_words(message.created_at) %>
            </div>

            <div class="mt-3">
              <%= link_to private_message_path(message), class: "btn btn-sm btn-outline" do %>
                <i class="fas fa-eye mr-1"></i> Öffnen
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <%# Desktop View (Table) %>
    <div class="hidden lg:block table-container">
      <table class="table-standard">
        <thead>
          <tr>
            <th class="table-th w-auto">Mit</th>
            <th class="table-th w-auto">Letzte Nachricht</th>
            <th class="table-th w-32">Datum</th>
            <th class="table-th w-32 text-center">Aktionen</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @messages.each do |message| %>
            <% other_user = message.sender_id == Current.user.id ? message.receiver : message.sender %>
            <% has_unread = @unread_partner_ids.include?(other_user.id) %>
            <tr class="table-tr-hover">
              <td class="table-td">
                <%= user_badge(other_user) %>
              </td>
              <td class="table-td">
                <%= link_to truncate(message.body, length: 80), private_message_path(message),
                  class: "hover:underline #{'font-semibold' if has_unread}" %>
                <% if has_unread %>
                  <span class="ml-2 inline-block w-2 h-2 bg-cs-dark-red rounded-full align-middle"></span>
                <% end %>
              </td>
              <td class="table-td text-gray-500 text-sm">
                <%= message.created_at.strftime("%d.%m.%Y") %>
              </td>
              <td class="table-td text-center">
                <%= link_to private_message_path(message),
                  class: "text-gray-400 hover:text-cs-dark-red" do %>
                  <i class="fas fa-eye"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-12 text-gray-500">
      <i class="fas fa-paper-plane text-4xl mb-4"></i>
      <p>Keine Konversationen</p>
    </div>
  <% end %>

  <%# Pagination %>
  <% if @pagy.pages > 1 %>
    <div class="flex justify-center">
      <%== @pagy.series_nav %>
    </div>
  <% end %>
</div>
