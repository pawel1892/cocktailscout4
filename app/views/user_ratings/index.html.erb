<% content_for :head do %>
  <script>window.userRatingData = <%= raw @user_ratings_json %>;</script>
<% end %>

<div class="mb-6 flex items-center gap-3">
  <%= link_to users_path, class: "text-gray-400 hover:text-gray-600 transition-colors" do %>
    <i class="fas fa-arrow-left"></i>
  <% end %>
  <div>
    <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Bewertungen von</p>
    <h1 class="text-2xl font-bold leading-tight"><%= @user.username %></h1>
  </div>
</div>

<user-rating-distribution></user-rating-distribution>

<div class="mt-4">
  <%= link_to users_path, class: "btn btn-outline btn-sm" do %>
    <i class="fas fa-arrow-left mr-1"></i> Zurück zur Benutzerliste
  <% end %>
</div>
